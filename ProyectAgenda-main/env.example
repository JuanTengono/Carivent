# Base
PORT=3001
DATABASE_URL=postgresql://user:pass@localhost:5432/eventos
# On Railway, DATABASE_URL is automatically injected by the PostgreSQL service.
# Do NOT hardcode a localhost URL in production — Railway provides this variable directly.
FRONTEND_URL=http://localhost:5173

# Stripe (modo prueba / sandbox) — obligatorio para checkout web con tarjeta
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Solo si necesitas el endpoint legacy POST /tickets/create-ticket sin Stripe (p. ej. tests manuales)
# ALLOW_LEGACY_IMMEDIATE_TICKET_PURCHASE=true
