# ==========================================
# CONFIGURACIÓN DE ENTORNO - CARIVENT BACKEND
# ==========================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/carivent?schema=public"

# On Railway, DATABASE_URL is automatically injected by the PostgreSQL service.
# Do NOT hardcode a localhost URL in production — Railway provides this variable directly.

# JWT
JWT_SECRET="cambia_este_secreto_por_uno_seguro_largo"
JWT_EXPIRES_IN=3600

# ==========================================
# VERIFICACIÓN DE EMAIL
# ==========================================
# Activar bloqueo de login si email no verificado
REQUIRE_EMAIL_VERIFICATION=true

# Tiempo de vida de tokens (minutos)
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ==========================================
# CONFIGURACIÓN DE EMAIL (Elegir una opción)
# ==========================================

# --- OPCIÓN 1: SMTP (ej: Gmail, Mailtrap) ---
EMAIL_PROVIDER=smtp
EMAIL_TRANSPORT=smtp
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="tu_usuario_mailtrap"
SMTP_PASS="tu_password_mailtrap"
SMTP_FROM="Carivent <noreply@carivent.com>"

# --- OPCIÓN 2: Brevo (ex Sendinblue) ---
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY="xkeysib_tu_api_key_aqui"
# BREVO_SENDER_NAME="Carivent"
# BREVO_SENDER_EMAIL="noreply@carivent.com"

# --- OPCIÓN 3: Modo stub (no envía real, solo log) ---
# EMAIL_PROVIDER=stub
# EMAIL_TRANSPORT=stub

# ==========================================
# APP LINKS (Para deep links móviles opcional)
# ==========================================
APP_DEEP_LINK_SCHEME=carivent
APP_DEEP_LINK_HOST=auth
APP_LINK_BRIDGE_BASE_URL=http://localhost:5173
