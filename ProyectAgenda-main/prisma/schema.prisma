generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Roles {
  id              Int               @id @default(autoincrement())
  name            String
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  users           User[]
  rolePermissions RolePermissions[]

  @@unique([name, deletedAt])
  @@map("roles")
}

enum StatusUser {
  ACTIVE
  INACTIVE
}

enum TypePermission {
  CREATE
  READ
  UPDATE
  DELETE
}

model User {
  id              Int               @id @default(autoincrement())
  name            String
  email           String
  password        String
  emailVerified   Boolean           @default(false) @map("email_verified")
  emailVerifiedAt DateTime?         @map("email_verified_at")
  roleId          Int
  role            Roles             @relation(fields: [roleId], references: [id])
  status          StatusUser        @default(ACTIVE)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  tokens          TokensUser[]
  sites           Sites[]
  events          Events[]
  tickets         Tickets[]
  payments        Payments[]
  notifications   Notifications[]
  notificationDevices NotificationDevices[]
  surveys         Surveys[]
  surveyResponses SurveyResponses[]
  promotions      Promotions[]
  authTokens      UserAuthTokens[]

  @@unique([email, deletedAt])
  @@map("users")
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model UserAuthTokens {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id])
  type      AuthTokenType
  tokenHash String        @map("token_hash")
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  @@unique([type, tokenHash, deletedAt])
  @@index([userId, type, deletedAt])
  @@map("user_auth_tokens")
}

model TokensUser {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([token, deletedAt])
  @@map("tokens_users")
}

model Permissions {
  id              Int               @id @default(autoincrement())
  name            String
  type            TypePermission
  description     String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  rolePermissions RolePermissions[]

  @@unique([name, type, deletedAt])
  @@map("permissions")
}

model RolePermissions {
  id           Int         @id @default(autoincrement())
  roleId       Int         @map("role_id")
  role         Roles       @relation(fields: [roleId], references: [id])
  permissionId Int         @map("permission_id")
  permission   Permissions @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

enum StatusSite {
  ACTIVE
  INACTIVE
}

model Sites {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  ubication   String?
  direction   String?
  imageUrl    String?    @map("image_url")
  latitude    Float?
  longitude   Float?
  phone       String?
  email       String?
  capacity    Int?
  userId      Int        @map("user_id")
  user        User       @relation(fields: [userId], references: [id])
  status      StatusSite @default(ACTIVE)
  events      Events[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  @@map("sites")
}

enum TypeEvent {
  PUBLIC
  PRIVATE
}

enum StatusEvent {
  PENDING
  IN_PROGRESS
  CONFIRMED
  CANCELLED
  COMPLETED
  ARCHIVED
}

model Events {
  id                Int          @id @default(autoincrement())
  name              String
  type              TypeEvent
  status            StatusEvent  @default(PENDING)
  description       String?
  imageUrl          String?      @map("image_url")
  ticketPrice       Decimal      @default(0) @map("ticket_price") @db.Decimal(10, 2)
  maxTicketsPerUser Int          @default(1) @map("max_tickets_per_user")
  startTime         DateTime     @map("start_time")
  endTime           DateTime     @map("end_time")
  siteId            Int          @map("site_id")
  site              Sites        @relation(fields: [siteId], references: [id])
  userId            Int          @map("user_id")
  user              User         @relation(fields: [userId], references: [id])
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")
  agendas           Agendas[]
  tickets           Tickets[]
  surveys           Surveys[]
  promotions        Promotions[]
  payments          Payments[]

  @@map("events")
}

enum StatusAgenda {
  PENDING
  IN_PROGRESS
  CONFIRMED
  CANCELLED
  COMPLETED
  ARCHIVED
}

model Agendas {
  id        Int          @id @default(autoincrement())
  activity  String
  eventId   Int          @map("event_id")
  event     Events       @relation(fields: [eventId], references: [id])
  startTime DateTime     @map("start_time")
  endTime   DateTime     @map("end_time")
  status    StatusAgenda @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  @@map("agendas")
}

enum StatusTicket {
  ACTIVE
  INACTIVE
  AVAILABLE
  PAYMENT_PENDING
  PURCHASED
  USED
  CANCELLED
  EXPIRED
}

model Tickets {
  id          Int          @id @default(autoincrement())
  codeQr      String       @unique @map("code_qr")
  eventId     Int          @map("event_id")
  event       Events       @relation(fields: [eventId], references: [id])
  userId      Int          @map("user_id")
  user        User         @relation(fields: [userId], references: [id])
  paymentId   Int?         @map("payment_id")
  payment     Payments?    @relation(fields: [paymentId], references: [id])
  amount      Decimal      @default(0) @db.Decimal(10, 2)
  validated   Boolean      @default(false)
  validatedAt DateTime?    @map("validated_at")
  status      StatusTicket @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  @@map("tickets")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Promotions {
  id            Int          @id @default(autoincrement())
  code          String
  title         String
  description   String?
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  minQuantity   Int          @default(1) @map("min_quantity")
  maxUses       Int?         @map("max_uses")
  usedCount     Int          @default(0) @map("used_count")
  validFrom     DateTime?    @map("valid_from")
  validTo       DateTime?    @map("valid_to")
  isActive      Boolean      @default(true) @map("is_active")
  eventId       Int?         @map("event_id")
  event         Events?      @relation(fields: [eventId], references: [id])
  userId        Int          @map("user_id")
  user          User         @relation(fields: [userId], references: [id])
  payments      Payments[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  @@unique([code, deletedAt])
  @@map("promotions")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Payments {
  id             Int           @id @default(autoincrement())
  userId         Int           @map("user_id")
  user           User          @relation(fields: [userId], references: [id])
  eventId        Int           @map("event_id")
  event          Events        @relation(fields: [eventId], references: [id])
  promotionId    Int?          @map("promotion_id")
  promotion      Promotions?   @relation(fields: [promotionId], references: [id])
  quantity       Int
  subtotal       Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency       String        @default("COP")
  status                PaymentStatus @default(PAID)
  provider              String?
  reference             String?
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  paidAt                DateTime?     @map("paid_at")
  metadata       Json?
  tickets        Tickets[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  @@map("payments")
}

enum NotificationType {
  SYSTEM
  PURCHASE
  PROMOTION
  REMINDER
  SURVEY
  EVENT
}

model Notifications {
  id        Int              @id @default(autoincrement())
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false) @map("is_read")
  userId    Int              @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  @@map("notifications")
}

model NotificationDevices {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  provider  String
  platform  String
  token     String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId, deletedAt])
  @@map("notification_devices")
}

model Surveys {
  id          Int               @id @default(autoincrement())
  titleSurvey String            @map("title_survey")
  eventId     Int               @map("event_id")
  event       Events            @relation(fields: [eventId], references: [id])
  userId      Int               @map("user_id")
  user        User              @relation(fields: [userId], references: [id])
  responses   SurveyResponses[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  @@map("surveys")
}

model SurveyResponses {
  id        Int       @id @default(autoincrement())
  surveyId  Int       @map("survey_id")
  survey    Surveys   @relation(fields: [surveyId], references: [id])
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  stars     Int
  comment   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("survey_responses")
}
