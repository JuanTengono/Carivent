# Destino del API en desarrollo (debe coincidir con PORT del backend en ProyectAgenda-main/.env).
# Si el puerto 3000 está libre y tu backend usa 3000, pon: http://127.0.0.1:3000
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# URL completa del backend del chatbot (servicio independiente del API principal).
# Ejemplo local: http://localhost:3002/api/chat
VITE_CHAT_API_URL=http://localhost:3001/api/chat
